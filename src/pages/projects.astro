---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div class="pb-4 mt-2">
    <div class="text-3xl w-full font-bold mb-1">Projects</div>
    <p class="text-sm opacity-60">Research projects and systems I have developed or contributed to.</p>
  </div>

  <!-- Core Research Projects -->
  <div class="text-2xl w-full font-bold mb-4 mt-4">Core Research</div>

  <HorizontalCard
    title="DPEP: Differentiable Predictive Ethics-Aware Planner"
    img="/research/dpep.png"
    desc="An end-to-end differentiable framework that learns ethical decision-making weights from naturalistic driving data. Validated on Waymo, NGSIM, HighD, and inD datasets. Designed for regulatory alignment with UNESCO and EU AI ethics frameworks."
    url="/research#ethics"
    target="_self"
    badge="Under Review"
    tags={["PyTorch", "Waymo", "Ethics"]}
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Goal-based Neural Physics (GNP) Trajectory Prediction"
    img="/research/gnp.png"
    desc="A physics-constrained deep learning model that predicts vehicle trajectories by first inferring driver goals and then generating dynamically feasible paths via neural ODEs."
    url="https://arxiv.org/abs/2409.15182"
    badge="TRB 2025"
    tags={["PyTorch", "Neural ODE", "NGSIM"]}
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="CrashSight: VLM-based Traffic Accident Analysis"
    img="/research/crashsight.png"
    desc="Fine-tuning video vision-language models (Qwen2-VL, VideoLLaMA2) for automated traffic crash analysis using a custom VQA dataset built from accident footage with curriculum learning."
    url="/research#vlm"
    target="_self"
    badge="In Progress"
    tags={["Qwen2-VL", "VideoLLaMA2", "VQA"]}
  />

  <!-- Infrastructure & Systems Projects -->
  <div class="text-2xl w-full font-bold mb-4 mt-10">Infrastructure & Systems</div>

  <HorizontalCard
    title="CAVH Architecture & V2X Systems"
    img="/research/v2x_vlm.png"
    desc="Research within the Connected and Automated Vehicle Highway (CAVH) framework, including IRIS, VIU, and RCS subsystems. V2X communication data pipeline development for connected vehicle applications."
    url="https://cavh.cee.wisc.edu/"
    tags={["V2X", "C-V2X", "Infrastructure"]}
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="PII Detection in Crash Narratives"
    img="/post_img.webp"
    desc="Fine-tuned Llama 3.1-8B model for detecting personally identifiable information in Wisconsin crash report narratives, enabling privacy-preserving data sharing for transportation research."
    url="#"
    badge="TRB 2026"
    tags={["Llama 3.1", "LoRA", "NLP"]}
  />
</BaseLayout>
