    <h1 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">CrashSight: A Phase-Aware, Infrastructure-Centric Video Benchmark for Traffic Crash Scene Understanding and Reasoning</h1>

    <div class="flex flex-wrap justify-center gap-x-1 gap-y-1 text-sm mt-4">
      <a href="/" class="font-semibold text-primary hover:underline">Rui Gan<sup>1</sup></a><span>,</span>
      <span>Junyi Ma<sup>1</sup>,</span>
      <span>Pei Li<sup>2</sup>,</span>
      <span>Xingyou Yang<sup>1</sup>,</span>
      <span>Kai Cheng<sup>1</sup>,</span>
      <span>Sikai Chen<sup>1</sup>,</span>
      <span>Bin Ran<sup>1</sup></span>
    </div>
    <p class="text-sm opacity-60 mt-2"><sup>1</sup>University of Wisconsin–Madison &nbsp; <sup>2</sup>University of Wyoming</p>
  </div>

  <!-- ===== ACTION BUTTONS ===== -->
